<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- The chaos server (retry-sample:server) is plain HTTP, reached via the emulator's
         10.0.2.2 alias or a LAN IP on a physical device (see PlatformServerHost.android.kt).
         Since targetSdk >= 28, cleartext traffic is blocked by default — iOS doesn't need this
         because App Transport Security already exempts localhost automatically. This sample is
         never published, so allowing cleartext app-wide is fine here; a shipped app should scope
         this to specific hosts via a Network Security Config instead. -->
    <application
        android:name=".RetryJournalSampleApplication"
        android:allowBackup="true"
        android:label="RetryJournal Sample"
        android:theme="@android:style/Theme.Material.Light.NoActionBar"
        android:usesCleartextTraffic="true">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@android:style/Theme.Material.Light.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
